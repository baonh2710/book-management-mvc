<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Sách</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

    <h1 class="text-center mb-4">📚 Quản lý Kho Sách</h1>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Thêm sách mới</h5>
            <form action="/books/add" method="POST" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="title" class="form-control" placeholder="Tên sách" required>
                </div>
                <div class="col-md-3">
                    <input type="text" name="author" class="form-control" placeholder="Tác giả" required>
                </div>
                <div class="col-md-3">
                    <input type="number" name="year" class="form-control" placeholder="Năm xuất bản">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">Thêm</button>
                </div>
            </form>
        </div>
    </div>

    <table class="table table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Tên sách</th>
                <th>Tác giả</th>
                <th>Năm</th>
                <th class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach(book => { %>
                <tr>
                    <td><%= book.title %></td>
                    <td><%= book.author %></td>
                    <td><%= book.year %></td>
                    <td class="text-center">
                        <form action="/books/delete/<%= book._id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Xóa thật nhé?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</body>
</html>